<div id="<%= dom_id property %>" class="group cursor-pointer">
  <div class="aspect-square w-full bg-gray-200 rounded-xl mb-3 overflow-hidden transition group-hover:opacity-90">
    <% if property.photo.attached? %>
      <%= image_tag property.photo, class: "w-full h-full object-cover" %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center text-gray-400">
        Sin foto
      </div>
    <% end %>
  </div>

  <div class="flex justify-between items-start">
    <div>
      <h3 class="font-semibold text-gray-900"><%= property.location %></h3>
      <p class="text-gray-500 text-sm truncate w-48"><%= property.title %></p>
      <p class="text-gray-400 text-xs mt-1">Anfitrión: <%= property.user ? property.user.email : 'Desconocido' %></p>
      <p class="text-gray-500 text-sm"><%= property.bedrooms %> habitaciones</p>
      <div class="mt-1 flex items-center gap-1">
        <span class="font-semibold text-gray-900">$<%= property.price %></span>
        <span class="text-gray-900 text-sm">noche</span>
      </div>
    </div>
  </div>
  
  <%= link_to "Ver detalles", property, class: "mt-3 text-sm text-blue-600 underline" %>
</div>